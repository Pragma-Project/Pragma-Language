constant int LIMIT = 5

object Vec2
  double x
  double y

  function dot(Vec2 other) returns double
    return self.x * other.x + self.y * other.y
  end function

  function magnitude_sq() returns double
    return self.x * self.x + self.y * self.y
  end function
end object

function power(int base, int exp) returns int
  int result = 1
  for int i = 0 while i < exp do i++
    result *= base
  end for
  return result
end function

function min_of(int a, int b) returns int
  if a < b
    return a
  end if
  return b
end function

function main()
  print LIMIT

  // Powers of 2
  for int i = 0 while i < LIMIT do i++
    print power(2, i)
  end for

  // Vec2 dot product
  Vec2 v1 = new Vec2[3.0, 4.0]
  Vec2 v2 = new Vec2[1.0, 2.0]
  print v1.dot(v2)
  print v1.magnitude_sq()

  // List: sum of squares
  List[int] nums = [1, 2, 3, 4, 5]
  int total = 0
  for each n in nums
    total += n * n
  end for
  print total

  // min_of chain
  int m = min_of(min_of(99, 42), min_of(7, 13))
  print m

  // Complex boolean
  int a = 4
  int b = 8
  bool check = (a * 2 == b) and (b > a)
  print check
end function
