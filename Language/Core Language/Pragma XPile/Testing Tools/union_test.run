function add(int a, int b) returns int
  return a + b
end function

function sub(int a, int b) returns int
  return a - b
end function

function mul(int a, int b) returns int
  return a * b
end function

function apply(BinOp op, int a, int b) returns int
  return op(a, b)
end function

function compare_asc(none a, none b) returns int
  return deref(change(a)-><int>) - deref(change(b)-><int>)
end function

function main()
  Word w
  w.i = 0x41424344
  print w.bytes[0] print w.bytes[1] print w.bytes[2] print w.bytes[3]
  w.f = 1.5f
  print w.f
  Colour c
  c.rgba.r = 255
  c.rgba.g = 128
  c.rgba.b = 0
  c.rgba.a = 255
  print c.rgba.r print c.rgba.g print c.rgba.b
  print c.packed != 0
  array BinOp[3] ops = [add, sub, mul]
  array string[3] names = ["add", "sub", "mul"]
  for int i = 0 while i < 3 do i++
    print names[i] print ops[i](10, 3)
  end for
  print apply(add, 7, 8)
  print apply(mul, 4, 5)
  array int[6] arr = [5, 2, 8, 1, 9, 3]
  qsort(arr, 6, size(int), compare_asc)
  for int i = 0 while i < 6 do i++
    print arr[i]
  end for
  return 0
end function
