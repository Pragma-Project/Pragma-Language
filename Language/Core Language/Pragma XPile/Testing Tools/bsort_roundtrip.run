function insertion_sort(int <arr>, int n) returns void
  for int i = 1 while i < n do i++
    int key = arr[i]
    int j = i - 1
    while (j >= 0) and (arr[j] > key) do
      arr[j + 1] = arr[j]
      j -= 1
    end do
    arr[j + 1] = key
  end for
end function

function binary_search(int <arr>, int n, int target) returns int
  int lo = 0
  int hi = n - 1
  while lo <= hi do
    int mid = lo + ((hi - lo) / 2)
    if arr[mid] == target
      return mid
    end if
    if arr[mid] < target
      lo = mid + 1
    else
      hi = mid - 1
    end if
  end do
  return -1
end function

function merge(int <arr>, int lo, int mid, int hi) returns void
  int n1 = (mid - lo) + 1
  int n2 = hi - mid
  int <left_v> = change(malloc(size(int) * n1))-><int>
  int <right_v> = change(malloc(size(int) * n2))-><int>
  for int i = 0 while i < n1 do i++
    left_v[i] = arr[lo + i]
  end for
  for int j = 0 while j < n2 do j++
    right_v[j] = arr[(mid + 1) + j]
  end for
  int i = 0
  int j = 0
  int k = lo
  while (i < n1) and (j < n2) do
    if left_v[i] <= right_v[j]
      arr[k] = left_v[i]
      i++
    else
      arr[k] = right_v[j]
      j++
    end if
    k++
  end do
  while i < n1 do
    arr[k] = left_v[i]
    i++
    k++
  end do
  while j < n2 do
    arr[k] = right_v[j]
    j++
    k++
  end do
  free(left_v)
  free(right_v)
end function

function merge_sort(int <arr>, int lo, int hi) returns void
  if lo < hi
    int mid = lo + ((hi - lo) / 2)
    merge_sort(arr, lo, mid)
    merge_sort(arr, mid + 1, hi)
    merge(arr, lo, mid, hi)
  end if
end function

function main()
  array[int] a = [5, 3, 8, 1, 9, 2, 7, 4, 6]
  int n = 9
  insertion_sort(a, n)
  for int i = 0 while i < n do i++
    print a[i]
  end for
  print ""
  int idx = binary_search(a, n, 7)
  print idx
  array[int] b = [42, 17, 99, 3, 55, 28, 71]
  int m = 7
  merge_sort(b, 0, m - 1)
  for int i = 0 while i < m do i++
    print b[i]
  end for
  print ""
  return 0
end function
