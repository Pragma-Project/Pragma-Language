int MAX_SPEED = 100
constant int Priority_low = 1
constant int Priority_medium = 2
constant int Priority_high = 3

// interface Athlete (vtable — use interface keyword)

object Runner
  String name
  int age
  double speed
end object

// constructor newRunner — auto-generated by Pragma from object declaration

object Cyclist
  Runner base
  int bikeType
end object

// constructor newCyclist — auto-generated by Pragma from object declaration

function Cyclist_Train(pointer Cyclist self) returns void
  print "Cyclist training"
end function

function Cyclist_GetSpeed(pointer Cyclist self) returns int
  return change(self.speed)->int
end function

function Add(int a, int b) returns int
  return a + b
end function

function Factorial(int n) returns int
  if n <= 1
    return 1
  end if
  return n * Factorial(n - 1)
end function

function main()
  int x = 10
  double pi = 3.14159
  String msg = "Pragma works"
  int done = 0
  print msg
  print Add(3, 7)
  print Factorial(6)
  print MAX_SPEED
  x += 5
  x *= 2
  print x
  if x > 30
    print "large"
  else if x > 15
    print "medium"
  else
    print "small"
  end if
  int count = 0
  while count < 3 do
    count++
    print count
  end do
  for int i = 0 while i < 4 do i++
    print i
  end for
  array[int] scores = [95, 87, 72, 100]
  array[String] names = ["Alice", "Bob", "Carol"]
  for int __i = 0 while __i < names_len do __i++
    String name = names[__i]
    print name
  end for
  int j = 0
  while j < 10 do
    j++
    if j == 5
      escape
    end if
    if j % 2 == 0
      skip
    end if
    print j
  end do
  int code = 2
  // switch (code) — review manually
  // case 1:
  print "one"
  // break (end of case)
  // case 2:
  print "two"
  // break (end of case)
  // case 3:
  print "three"
  print "still three"
  // break (end of case)
  // default:
  print "other"
  // break (end of case)
  int p = Priority_high
  print p
  int flags = 0
  flags = flags or 4
  flags = flags ^ 1
  flags = flags left 2
  flags = flags right 1
  flags = ~flags
  print flags
  double f = 3.9
  int truncated = change(f)->int
  print truncated
  Runner r = newRunner("Jake", 24, 9.8)
  print r.name
  String blank = NULL
  int nothing = 0
  return 0
end function
