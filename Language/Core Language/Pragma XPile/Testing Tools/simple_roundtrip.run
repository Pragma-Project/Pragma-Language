constant int MAX = 10
constant double PI = 3.14159

function add(int a, int b) returns int
  return a + b
end function

function factorial(int n) returns int
  if n <= 1
    return 1
  end if
  return n * factorial(n - 1)
end function

function clamp(int val, int lo, int hi) returns int
  if val < lo
    return lo
  else if val > hi
    return hi
  end if
  return val
end function

function is_prime(int n) returns int
  if n < 2
    return 0
  end if
  for int i = 2 while i * i <= n do i++
    if n % i == 0
      return 0
    end if
  end for
  return 1
end function

function main()
  print add(3, 7)
  print factorial(6)
  print clamp(150, 0, 100)
  print clamp(-5, 0, 100)
  int sum = 0
  for int i = 1 while i <= MAX do i++
    sum += i
  end for
  print sum
  int count = 0
  int j = 1
  while j <= 20 do
    if is_prime(j)
      count++
    end if
    j++
  end do
  print count
  int flags = 0b1010
  flags = flags and 0b1100
  flags = flags or 1
  flags = flags ^ 3
  flags = flags left 1
  flags = flags right 1
  print flags
  double x = 3.7
  int truncated = change(x)->int
  print truncated
  return 0
end function
