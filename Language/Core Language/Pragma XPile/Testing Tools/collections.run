object Point
  int x
  int y

  function describe() returns void
    print self.x
    print self.y
  end function
end object

function max(int a, int b) returns int
  if a > b
    return a
  end if
  return b
end function

function main()
  // Array
  array[int] scores = [95, 87, 72, 100, 64]
  int total = 0
  for int i = 0 while i < 5 do i++
    total += scores[i]
  end for
  print total

  // List with for-each
  List[String] names = ["Alice", "Bob", "Carol"]
  for each name in names
    print name
  end for

  // Object construction and field access
  Point p = new Point[3, 7]
  print p.x
  print p.y
  p.describe()

  // conditions (match no fall-through)
  int code = 2
  conditions code
    1: print "one"
    2: print "two"
    3: print "three"
    default: print "other"
  end conditions

  // max function
  print max(14, 9)
end function
