constant int MAX_WORDS = 20

array string[20] keys
array int[20] counts
int n_words = 0
function word_inc(string word) returns void
  for int i = 0 while i < n_words do i++
    if strcmp(keys[i], word) == 0
      counts[i]++
      return
    end if
  end for
  if n_words < MAX_WORDS
    keys[n_words] = word
    counts[n_words] = 1
    n_words++
  end if
end function

function word_get(string word) returns int
  for int i = 0 while i < n_words do i++
    if strcmp(keys[i], word) == 0
      return counts[i]
    end if
  end for
  return 0
end function

function day_name(int d) returns string
  switch d
  when 0
    return "Sunday"
  when 1
    return "Monday"
  when 2
    return "Tuesday"
  when 3
    return "Wednesday"
  when 4
    return "Thursday"
  when 5
    return "Friday"
  when 6
    return "Saturday"
  default
    return "Unknown"
  end switch
end function

function token_class(char c) returns string
  switch c
  when 97
  when 101
  when 105
  when 111
  when 117
    return "vowel"
  when 32
  when 9
  when 10
    return "space"
  default
    return "other"
  end switch
end function

function main()
  for int d = 0 while d <= 6 do d++
    print day_name(d)
  end for
  print token_class(97)
  print token_class(101)
  print token_class(98)
  array string words = ["the", "cat", "sat", "on", "the", "mat", "the", "cat"]
  int nw = 8
  for int i = 0 while i < nw do i++
    word_inc(words[i])
  end for
  print word_get("the")
  print word_get("cat")
  print word_get("sat")
  print word_get("on")
  print word_get("mat")
  return 0
end function
