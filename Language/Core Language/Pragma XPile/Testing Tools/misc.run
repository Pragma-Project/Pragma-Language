function abs_val(int n) returns int
  if n < 0
    return -n
  end if
  return n
end function

function is_prime(int n) returns bool
  if n < 2
    return false
  end if
  for int i = 2 while i * i <= n do i++
    if n % i == 0
      return false
    end if
  end for
  return true
end function

function fizzbuzz(int n) returns void
  int i = 1
  while i <= n do
    if i % 15 == 0
      print "FizzBuzz"
    else if i % 3 == 0
      print "Fizz"
    else if i % 5 == 0
      print "Buzz"
    else
      print i
    end if
    i++
  end do
end function

function main()
  print abs_val(-7)
  print abs_val(5)

  print is_prime(7)
  print is_prime(9)
  print is_prime(2)

  // skip (continue in loop) — sum odd numbers 1..10
  int sum = 0
  for int i = 1 while i <= 10 do i++
    if i % 2 == 0
      skip
    end if
    sum += i
  end for
  print sum

  fizzbuzz(15)
end function
