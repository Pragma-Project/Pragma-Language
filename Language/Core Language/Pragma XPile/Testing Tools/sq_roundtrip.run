type Stack
  int <data>
  int top
  int cap
end type

function stack_new(int initial_cap) returns Stack
  Stack s
  s.data = change(malloc(size(int) * initial_cap))-><int>
  s.top = 0
  s.cap = initial_cap
  return s
end function

function stack_push(Stack <s>, int val) returns void
  if s.top == s.cap
    s.cap *= 2
    s.data = change(realloc(s.data, size(int) * s.cap))-><int>
  end if
  s.data[s.top] = val
  s.top += 1
end function

function stack_pop(Stack <s>) returns int
  s.top -= 1
  return s.data[s.top]
end function

function stack_peek(Stack <s>) returns int
  return s.data[s.top - 1]
end function

function stack_empty(Stack <s>) returns int
  return s.top == 0
end function

type Queue
  int <data>
  int head
  int tail
  int size
  int cap
end type

function queue_new(int cap) returns Queue
  Queue q
  q.data = change(malloc(size(int) * cap))-><int>
  q.head = 0
  q.tail = 0
  q.size = 0
  q.cap = cap
  return q
end function

function queue_enqueue(Queue <q>, int val) returns void
  q.data[q.tail] = val
  q.tail = q.tail + 1 % q.cap
  q.size += 1
end function

function queue_dequeue(Queue <q>) returns int
  int val = q.data[q.head]
  q.head = q.head + 1 % q.cap
  q.size -= 1
  return val
end function

function queue_empty(Queue <q>) returns int
  return q.size == 0
end function

function main()
  Stack s = stack_new(4)
  for int i = 1 while i <= 5 do i++
    stack_push(address(s), i * 10)
  end for
  while !stack_empty(address(s)) do
    print stack_pop(address(s))
  end do
  Queue q = queue_new(8)
  queue_enqueue(address(q), 100)
  queue_enqueue(address(q), 200)
  queue_enqueue(address(q), 300)
  queue_enqueue(address(q), 400)
  while !queue_empty(address(q)) do
    print queue_dequeue(address(q))
  end do
  return 0
end function
