type Node
  int value
  Node <next>
end type

type List
  Node <head>
  int length
end type

function list_new() returns List
  List l
  l.head = NULL
  l.length = 0
  return l
end function

function list_push(List <lst>, int val) returns void
  Node <n> = change(malloc(size(Node)))-><Node>
  n.value = val
  n.next = lst.head
  lst.head = n
  lst.length += 1
end function

function list_sum(List <lst>) returns int
  int total = 0
  Node <cur> = lst.head
  while cur != NULL do
    total += cur.value
    cur = cur.next
  end do
  return total
end function

function list_max(List <lst>) returns int
  if lst.head == NULL
    return 0
  end if
  int mx = lst.head.value
  Node <cur> = lst.head.next
  while cur != NULL do
    if cur.value > mx
      mx = cur.value
    end if
    cur = cur.next
  end do
  return mx
end function

function list_print(List <lst>) returns void
  Node <cur> = lst.head
  while cur != NULL do
    print cur.value
    cur = cur.next
  end do
end function

function main()
  List lst = list_new()
  list_push(address(lst), 10)
  list_push(address(lst), 30)
  list_push(address(lst), 20)
  list_push(address(lst), 5)
  print lst.length
  print list_sum(address(lst))
  print list_max(address(lst))
  list_print(address(lst))
  return 0
end function
