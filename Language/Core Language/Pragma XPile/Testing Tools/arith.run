MAIN
  int x = 10
  int y = 3

  print x + y
  print x - y
  print x * y
  print x / y
  print x % y

  float pi = 3.14159
  float r = 5.0
  float area = pi * r * r
  print area

  if x > y
    print "x is greater"
  else if x == y
    print "equal"
  else
    print "y is greater"
  end if
END MAIN
